{
  "manifest_version": 3,
  "name": "Shady CPH",
  "version": "1.2.0",
  "description": "Parses and sends CP testcases to localhost or logs to console.",
  "permissions": [
    "storage"
  ],
  "background": {
    "service_worker": "serviceWorker.js",
    "type": "module"
  },
  "action": {
    "default_popup": "src/popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://codeforces.com/contest/*",
        "https://codeforces.com/problemset/problem/*"
      ],
      "js": [
        "src/content.js"
      ]
    }
  ]
}